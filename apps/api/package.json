{
  "name": "@baker/api",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src",
    "start": "node dist/index.js",
    "test": "vitest run apps/api",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
