# Copy this file to `dev-test.local.env` and fill your local values.
# Do NOT commit `dev-test.local.env`.

TURN_HOST=your-domain.example.com
HTTPS_HOST=your-domain.example.com
HTTPS_PORT=443
TLS_MODE=public
ACME_EMAIL=you@example.com

# Optional: used for startup summary and firewall checklist output.
WEB_LAN_PORT=3233
API_PORT=3101
GATEWAY_PORT=3102
ADMIN_PORT=5180
POSTGRES_PORT=5432
REDIS_PORT=6379
TURN_PORT=3478
TURN_RELAY_MIN=49160
TURN_RELAY_MAX=49200
