    "@baker/protocol": "workspace:*",
    "@baker/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2"
  }
}
