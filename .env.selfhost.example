NODE_ENV=production

# Optional: create `.env` from this file before the first boot only if you want
# fixed credentials, custom ports, custom TURN settings, or different image tags.
# If you skip `.env`, `docker compose up -d` now auto-generates strong runtime
# secrets on first start and persists them in a Docker volume.

# Public entry ports on the host machine.
WEB_PORT=3000
ADMIN_HTTP_PORT=3001

# Local-only bind ports for direct host debugging (kept on 127.0.0.1 by compose).
POSTGRES_PORT=5432
REDIS_PORT=6379

POSTGRES_DB=baker
POSTGRES_USER=baker
POSTGRES_PASSWORD=

# Optional fixed secrets. Leave blank to let the bootstrap container generate
# strong persisted values on the first startup.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
MEDIA_INTERNAL_SECRET=
ADMIN_PANEL_PASSWORD=

# Legacy desktop bootstrap URL. Safe to leave at the default for web-only self-hosted deployments.
DESKTOP_DEV_SERVER_URL=http://localhost:5174

# Optional: restrict dev-server host allowlists when reusing env values outside docker dev.
VITE_ALLOWED_HOSTS=
ALLOWED_HOSTS=

# STUN is enabled by default. TURN is optional but recommended for reliable
# voice/stream connectivity across NAT, VPN, mobile, or cross-region networks.
STUN_URLS=stun:stun.cloudflare.com:3478,stun:stun.l.google.com:19302
TURN_URLS=
TURN_USERNAME=
TURN_PASSWORD=
TURN_REALM=baker
TURN_PORT=3478
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200

# Optional when running the bundled coturn container behind NAT:
# TURN_EXTERNAL_IP=203.0.113.10

# Optional: point Compose at a different published image registry/tag.
# The defaults pull from GHCR. If you also publish to Docker Hub, you can
# replace these with `your-dockerhub-user/...:latest` so Docker Desktop users
# can search/pull the main Baker image directly.
# BAKER_RUNTIME_IMAGE=ghcr.io/blockcat2333/baker:latest
# BAKER_POSTGRES_IMAGE=postgres:16-alpine
# BAKER_PROXY_IMAGE=ghcr.io/blockcat2333/baker-proxy:latest
