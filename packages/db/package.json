{
  "name": "@baker/db",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "lint": "eslint src drizzle.config.ts",
    "test": "vitest run packages/db",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.0",
    "tsup": "^8.3.5"
  }
}
