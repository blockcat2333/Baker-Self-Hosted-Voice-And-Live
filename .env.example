NODE_ENV=development

WEB_PORT=5173
DESKTOP_DEV_SERVER_URL=http://localhost:5174

API_HOST=0.0.0.0
API_PORT=3001

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=3002

MEDIA_HOST=0.0.0.0
MEDIA_PORT=3003

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=baker
POSTGRES_USER=baker
POSTGRES_PASSWORD=baker
DATABASE_URL=postgres://baker:baker@127.0.0.1:5432/baker

REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=replace-me-for-local-access
JWT_REFRESH_SECRET=replace-me-for-local-refresh
ADMIN_PANEL_PASSWORD=admin
MEDIA_INTERNAL_SECRET=replace-me-for-local-media-internal-secret

STUN_URLS=stun:stun.cloudflare.com:3478,stun:stun.l.google.com:19302
# For real-world reliability across NAT/VPN/mobile networks (especially cross-region),
# configure a TURN server and set TURN_URLS to a relay URL (prefer TCP/TLS):
#   TURN_URLS=turns:turn.example.com:5349?transport=tcp
#   TURN_USERNAME=...
#   TURN_PASSWORD=...
TURN_URLS=
TURN_USERNAME=
TURN_PASSWORD=

# Optional: helps TURN behind NAT/docker advertise the correct public IP.
# TURN_EXTERNAL_IP=203.0.113.10
# Optional: realm shown in TURN auth.
# TURN_REALM=baker
